{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": ["**/*.csproj"],
          "exclude": ["**/Backend.Tests/**", "**/bin/**", "**/obj/**"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["index.md", "toc.yml"],
        "exclude": ["README.md", "_site/**", "obj/**"]
      },
      {
        "files": ["docs/**/*.md", "docs/**/toc.yml"],
        "exclude": ["README.md"]
      },
      {
        "files": ["api/**/*.yml", "api/index.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "SkincareArchitect",
      "_appTitle": "SkincareArchitect Documentation",
      "_enableSearch": true,
      "pdf": false
    }
  }
}